apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: default
type: Opaque
stringData:
  PG_URL: "postgresql+asyncpg://user:pass@host:port/db"
  PG_USER: user
  PG_PASS: pass
  SECRET_KEY: "change-me"
  ACCESS_TOKEN_EXPIRE_MINUTES: "15"
  ALGORITHM: "HS256"
  REFRESH_TOKEN_EXPIRE_DAYS: "30"
